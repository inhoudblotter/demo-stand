# Global Settings
PROJECT_DOMAIN=вашдомен.ru
LETSENCRYPT_EMAIL=admin@вашдомен.ru

# --- AUTHENTICATION ---
# Global Admin Hash (for Traefik Dashboard at traefik.yourdomain.ru)
# Generate: echo $(htpasswd -nb admin password) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASH_AUTH_HASH=admin:$$apr1$$869p9Oqy$$6vR9.S8p9Of.pS.WJpSfU/

# --- POSTGRES INFRASTRUCTURE ---
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo123

# --- PROJECTS DATABASE MANAGEMENT ---
# Format: DB1:USER1:PASS1,DB2:USER2:PASS2
POSTGRES_MULTIPLE_DATABASES=p1_db:p1_user:p1_pass,p2_db:p2_user:p2_pass

# --- INDIVIDUAL PROJECT SETTINGS (Example) ---
PROJECT_NAME=myproject
# Each project can have its own auth hash in its own .env or here
PROJECT_AUTH_HASH=user1:$$apr1$$869p9Oqy$$6vR9.S8p9Of.pS.WJpSfU/
